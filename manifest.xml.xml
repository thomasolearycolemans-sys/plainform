<?xml version="1.0" encoding="UTF-8"?>
<!--
  ====================================================================
  Plainform — Word add-in manifest
  ====================================================================
  This file is the POINTER Word loads. It does not contain the add-in;
  it tells Word WHERE the add-in lives (the SourceLocation URL below).

  >>> THE ONE THING YOU MUST EDIT <<<
  Replace every occurrence of:
        https://thomasolearycolemans-sys.github.io/plainform
  with the public https address where you host taskpane.html.
  (e.g. your CodeSandbox / StackBlitz / GitHub Pages URL.)
  There are 4 spots: SourceLocation, two icon URLs, and AppDomains.

  After editing, save this file and sideload it into Word
  (Insert then My Add-ins then your shared-folder catalogue).
  ====================================================================
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- A unique ID for this add-in. This random GUID is fine to keep. -->
  <Id>aa1f1d98-e92d-4b11-9971-8b11275ee134</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Plainform</ProviderName>
  <DefaultLocale>en-AU</DefaultLocale>
  <DisplayName DefaultValue="Plainform"/>
  <Description DefaultValue="Plain-language editing to the Australian Government Style Manual."/>

  <!-- Icon shown in the add-ins list. -->
  <IconUrl DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/icon-64.png"/>

  <!-- Domains the add-in is allowed to load from. -->
  <AppDomains>
    <AppDomain>https://thomasolearycolemans-sys.github.io/plainform</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Document"/>   <!-- "Document" means Word -->
  </Hosts>

  <DefaultSettings>
    <!-- The page Word opens in the task pane: THIS is the pointer to our HTML. -->
    <SourceLocation DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- Modern ribbon button so Plainform appears on Word's Home tab. -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="PlainformGroup">
                <Label resid="Group.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16"/>
                  <bt:Image size="32" resid="Icon.32"/>
                  <bt:Image size="80" resid="Icon.80"/>
                </Icon>
                <Control xsi:type="Button" id="OpenPlainform">
                  <Label resid="Button.Label"/>
                  <Supertip>
                    <Title resid="Button.Label"/>
                    <Description resid="Button.Tip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>PlainformPane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <!-- EDIT these three icon URLs too (same host as above). -->
        <bt:Image id="Icon.16" DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/icon-32.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/icon-64.png"/>
      </bt:Images>
      <bt:Urls>
        <!-- EDIT this taskpane URL to match SourceLocation above. -->
        <bt:Url id="Taskpane.Url" DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/taskpane.html"/>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://thomasolearycolemans-sys.github.io/plainform/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Plainform is ready"/>
        <bt:String id="Group.Label" DefaultValue="Plainform"/>
        <bt:String id="Button.Label" DefaultValue="Plainform"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Open Plainform from the Home tab to start editing to the Style Manual."/>
        <bt:String id="Button.Tip" DefaultValue="Open the Plainform plain-language editor."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
